rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'rob.razzante@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'member') == 'admin')
      );
    }

    function userStatus() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('status', 'pending');
    }

    function isApproved() {
      return isSignedIn() && (isAdmin() || userStatus() == 'approved');
    }

    // Users — own doc readable by anyone signed in (to check status);
    // full directory only for approved users
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isApproved());
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Users can update their own profile but cannot change their own status or role
      allow update: if isAdmin()
                    || (isSignedIn() && request.auth.uid == userId
                        && request.resource.data.status == resource.data.status
                        && request.resource.data.get('role', 'member') == resource.data.get('role', 'member'));
      allow delete: if isAdmin();
    }

    // RSVPs
    match /rsvps/{docId} {
      allow read: if isApproved();
      allow create: if isApproved() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || (isApproved() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
    }

    // Memory Wall
    match /memories/{docId} {
      allow read: if isApproved();
      allow create: if isApproved() && request.resource.data.userId == request.auth.uid;
      allow update: if isApproved(); // needed for flag updates
      allow delete: if isAdmin();
    }

    // In Memoriam comments
    match /memoriam_comments/{docId} {
      allow read: if isApproved();
      allow create: if isApproved() && request.resource.data.userId == request.auth.uid;
      allow update: if isApproved(); // needed for flag updates
      allow delete: if isAdmin();
    }

    // Teacher portal — open create and public read (teachers visit without signing in)
    match /teachers/{docId} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if isAdmin();
    }

    // Reunion suggestions
    match /reunion_suggestions/{docId} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update, delete: if isAdmin();
    }

    // Alumni membership
    match /alumni_membership/{docId} {
      allow read: if isApproved();
      allow create: if isApproved() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Donor wall — public read, admin-only write
    match /donors/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public stats (classmate count visible to everyone)
    match /stats/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
