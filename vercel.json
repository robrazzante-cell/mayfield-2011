{
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/__/auth/:path*",
            "destination": "https://mayfield-2011.firebaseapp.com/__/auth/:path*"
        }
    ]
}
